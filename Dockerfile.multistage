package actionbumper






























































ENTRYPOINT ["/opt/docker-entrypoint.sh"]# Initial command - uses entrypoint script to select implementationSHELL ["/bin/bash", "-eo", "pipefail", "-c"]# SHELLCOPY docker-entrypoint.sh /opt/docker-entrypoint.sh# Entrypoint script that chooses implementationCOPY bumper.sh bumper.shCOPY lib lib# Project files (Bash implementation)USER runtime# Set the runtime user to a non-root userCOPY --from=go-builder /build/bumper /opt/bumper-go# Copy Go binary from builder stage  chmod +x /usr/bin/semver  https://raw.githubusercontent.com/fsaintjacques/semver-tool/master/src/semver && \RUN wget -O /usr/bin/semver \  rm -rf /var/lib/apt/lists/*  xz-utils && \  wget \  jq \  gpg \  git \  curl \  bash \RUN apt update && apt install -y \# Install dependencies (needed for Bash implementation)  useradd --create-home --no-log-init -u 1001 -g 1001 runtimeRUN groupadd -g 1001 runtime && \# Add userWORKDIR /opt# WorkdirFROM ubuntu:25.10# Stage 2: Runtime imageRUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o bumper ./cmd/bumper# Build the Go binaryCOPY internal/ internal/COPY cmd/ cmd/# Copy source codeRUN go mod downloadCOPY go.mod go.sum ./# Copy Go module filesWORKDIR /buildFROM golang:1.24-alpine AS go-builder# Stage 1: Build Go binary# Multi-stage Dockerfile supporting both Bash and Go implementations# Copyright (c) 2024 Inetum Poland.